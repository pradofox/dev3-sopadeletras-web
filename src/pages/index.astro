---
import Base from '../layouts/Base.astro';
import ProjectListEditorial from '../components/ProjectListEditorial.astro';
import Status from '../components/Status.astro';
import Float from '../components/Float.astro';
import Wink from '../components/Wink.astro';
import Logo from '../components/Logo.astro';
import { getCollection } from 'astro:content';
import { team } from '../data/team';
import { awards } from '../data/awards';

export const prerender = true;

const portfolio = (await getCollection('portfolio'))
  .filter(p => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

const featured = portfolio.slice(0, 5).map(p => ({
  href: `/trabajo/${p.id}`,
  title: p.data.title,
  client: p.data.client,
  categories: p.data.categories,
  cover: p.data.cover,
  year: p.data.year,
}));
---

<Base>
  <!-- HERO: lede + señor caminando + wordmark gigante abajo -->
  <section class="hero" aria-label="Inicio">
    <div class="hero__lede">
      <p>
        Desarrollamos proyectos empresariales y de impacto cultural
        a través de estrategia creativa, diseño y producción audiovisual.
      </p>
    </div>

    <div class="hero__figure">
      <img
        src="/images/decor/senor-byn.png"
        alt=""
        class="hero__senor"
        loading="eager"
        decoding="async"
        draggable="false"
      />
      <p class="hero__tag">
        <span class="hero__tag-line">buenas</span>
        <span class="hero__tag-line hero__tag-line--alt">ideas <Wink /></span>
      </p>
    </div>

    <div class="hero__wordmark" aria-hidden="true">
      <Logo class="hero__logo" />
    </div>
  </section>

  <!-- STATUS bar -->
  <section class="status-bar wrap">
    <Status />
  </section>

  <hr class="hr" />

  <!-- TRABAJO seleccionado -->
  <section id="trabajo" class="sec sec--np">
    <header class="sec__head wrap">
      <p class="eye">Trabajo<span class="tabular">({portfolio.length})</span></p>
      <h2 class="sec__title">
        <span class="bold">Recientes</span>
        <span class="sec__title-meta tabular">/ 2024–2025</span>
      </h2>
    </header>

    <ProjectListEditorial items={featured} />

    <div class="wrap sec__more" data-reveal>
      <a href="/trabajo" class="more">
        <span>Ver los <span class="tabular">{portfolio.length}</span> proyectos</span>
        <span class="more__arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <hr class="hr" />

  <!-- NOSOTROS con float lápiz -->
  <section id="nosotros" class="wrap sec sec--np sec--rel">
    <Float src="/images/decor/pencil.png" alt="" label="nosotros" top="6%" left="4%" size="clamp(70px, 10vw, 130px)" rotate="-12deg" />

    <header class="sec__head sec__head--right">
      <p class="eye">Nosotros</p>
    </header>

    <p class="manifesto" data-reveal>
      Hacemos cosas que <span class="bold">se ven serias</span> porque nos las
      tomamos en serio. Pero por dentro somos <span class="bold">cero serios</span>
      <Wink />. Ese es el encanto sopa.
    </p>

    <div class="cols-2" data-reveal style="--reveal-delay: 200ms">
      <div>
        <p class="eye">Estudio pequeño, ágil</p>
        <p class="cols-2__p">
          Cuando contratas a sopadeletras® no te toca un junior. Te toca el equipo entero,
          de principio a fin. Trabajamos con cuidado, sin perder velocidad.
        </p>
      </div>
      <div>
        <p class="eye">Multidisciplinario</p>
        <p class="cols-2__p">
          Estrategia, branding, diseño, foto y video, web, editorial.
          Hacemos lo que el proyecto necesita, no lo que nos toque ofrecer.
        </p>
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- EQUIPO -->
  <section id="equipo" class="wrap sec sec--np sec--rel">
    <Float src="/images/decor/smiley.png" alt="" top="8%" right="6%" size="clamp(50px, 7vw, 90px)" rotate="14deg" />

    <header class="sec__head">
      <p class="eye">Equipo<span class="tabular">({team.length})</span></p>
    </header>

    <div class="team">
      {team.map((m, i) => (
        <article class="member" data-reveal style={`--reveal-delay: ${i * 120}ms`}>
          <span class="member__num eye tabular">{String(i+1).padStart(2,'0')} / {String(team.length).padStart(2,'0')}</span>
          <h3 class="member__name">{m.name}</h3>
          <p class="member__role">{m.role}</p>
          <blockquote class="member__quote">"{m.quote}"</blockquote>
          <ul class="member__links">
            {m.instagram && <li><a class="u" href={m.instagram} target="_blank" rel="noopener">Instagram</a></li>}
            {m.linkedin && <li><a class="u" href={m.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <hr class="hr" />

  <!-- PREMIOS -->
  <section id="premios" class="sec sec--np sec--rel">
    <Float src="/images/decor/shamrock.png" alt="" bottom="8%" left="3%" size="clamp(50px, 7vw, 100px)" rotate="-8deg" />

    <header class="wrap sec__head">
      <p class="eye">Reconocimientos<span class="tabular">({awards.length})</span></p>
    </header>

    <ul class="awards">
      {awards.map(a => (
        <li class="award" data-reveal>
          <div class="award__row wrap">
            <span class="award__year tabular">{a.year}</span>
            <span class="award__name"><span class="bold">{a.award}</span>{a.level && <span class="award__level"> · {a.level}</span>}</span>
            <span class="award__project">{a.project}</span>
            <span class="award__cat">{a.category}</span>
          </div>
          <hr class="hr" />
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  /* ========= HERO ========= */
  .hero {
    position: relative;
    min-height: calc(100dvh - 64px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr auto;
    column-gap: var(--sp-6);
    padding: clamp(2rem, 6vh, 5rem) var(--gutter) 0;
    overflow: hidden;
  }

  .hero__lede {
    grid-column: 1;
    grid-row: 1;
    align-self: end;
    padding-bottom: var(--sp-8);
    max-width: 28ch;
  }
  .hero__lede p {
    font-size: clamp(1.125rem, 1.6vw, 1.5rem);
    line-height: 1.35;
    font-weight: 300;
    color: var(--fg);
  }

  .hero__figure {
    grid-column: 2;
    grid-row: 1;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: clamp(1rem, 6vw, 6rem);
  }
  .hero__senor {
    height: clamp(280px, 45vh, 480px);
    width: auto;
    object-fit: contain;
    user-select: none;
    pointer-events: none;
    -webkit-user-drag: none;
  }
  .hero__tag {
    position: absolute;
    bottom: clamp(2rem, 8vh, 6rem);
    right: clamp(2rem, 12vw, 10rem);
    font-size: clamp(1.5rem, 2.6vw, 2.5rem);
    line-height: 1.05;
    font-weight: 300;
    text-align: left;
    pointer-events: none;
  }
  .hero__tag-line { display: block; }
  .hero__tag-line--alt { padding-left: 1.4em; }

  /* WORDMARK GIGANTE — pisado al bottom, full-width */
  .hero__wordmark {
    grid-column: 1 / -1;
    grid-row: 2;
    width: 100%;
    line-height: 0.85;
    margin-top: var(--sp-4);
    padding-bottom: clamp(0.5rem, 2vh, 1.5rem);
  }
  :global(.hero__logo) {
    display: block;
    width: 100%;
    height: auto;
    color: var(--fg);
  }

  /* MOBILE: stack vertical, figura + tag, lede, wordmark abajo */
  @media (max-width: 720px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      min-height: auto;
      padding-top: var(--sp-6);
    }
    .hero__figure {
      grid-column: 1;
      grid-row: 1;
      padding-right: 0;
      justify-content: center;
      padding-block: var(--sp-6);
    }
    .hero__senor { height: clamp(220px, 38vh, 320px); }
    .hero__tag {
      bottom: var(--sp-4);
      right: 50%;
      transform: translateX(80px);
    }
    .hero__lede {
      grid-column: 1;
      grid-row: 2;
      padding: var(--sp-4) 0 var(--sp-8);
      max-width: none;
      align-self: start;
    }
    .hero__wordmark {
      grid-column: 1;
      grid-row: 3;
      padding-bottom: var(--sp-3);
    }
  }

  /* ========= STATUS BAR ========= */
  .status-bar {
    padding-block: var(--sp-4) var(--sp-6);
  }

  /* ========= SECTIONS ========= */
  .sec { padding-block: clamp(3rem, 6vw, 5rem); }
  .sec--np { padding-block: clamp(3rem, 6vw, 5rem); }
  .sec--rel { position: relative; }
  .sec__head { margin-bottom: var(--sp-6); display: flex; flex-direction: column; gap: var(--sp-2); }
  .sec__head--right { align-items: flex-end; text-align: right; }
  .sec__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1;
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .sec__title .bold { font-weight: 700; }
  .sec__title-meta { font-size: var(--fs-md); color: var(--muted); font-weight: 300; }

  .sec__more { padding-top: var(--sp-6); display: flex; justify-content: flex-end; }
  .more {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-md);
    color: var(--fg);
    transition: opacity var(--dur);
  }
  .more__arrow { transition: transform var(--dur) var(--ease); }
  .more:hover { opacity: 0.6; }
  .more:hover .more__arrow { transform: translateX(4px); }

  /* ========= MANIFESTO ========= */
  .manifesto {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.3;
    letter-spacing: -0.02em;
    font-weight: 300;
    color: var(--fg);
    max-width: 32ch;
    margin-bottom: var(--sp-10);
  }
  .manifesto .bold { font-weight: 700; }

  .cols-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    border-top: 1px solid var(--hairline);
    padding-top: var(--sp-5);
  }
  @media (min-width: 720px) { .cols-2 { grid-template-columns: 1fr 1fr; gap: var(--sp-10); } }
  .cols-2 .eye { margin-bottom: var(--sp-2); }
  .cols-2__p { font-size: var(--fs-md); line-height: 1.5; max-width: 38ch; color: var(--fg); }

  /* ========= EQUIPO ========= */
  .team {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-8);
    border-top: 1px solid var(--hairline);
    padding-top: var(--sp-5);
  }
  @media (min-width: 768px) { .team { grid-template-columns: 1fr 1fr; gap: var(--sp-10); } }
  .member { display: flex; flex-direction: column; gap: var(--sp-3); }
  .member__num { font-size: var(--fs-xs); }
  .member__name {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 300;
    letter-spacing: -0.025em;
  }
  .member__role { color: var(--muted); font-size: var(--fs-md); }
  .member__quote {
    margin: 0;
    font-size: var(--fs-md);
    color: var(--fg);
    border-left: 1px solid var(--fg);
    padding-left: var(--sp-3);
    line-height: 1.45;
    max-width: 38ch;
  }
  .member__links { list-style: none; padding: 0; margin: 0; display: flex; gap: var(--sp-4); font-size: var(--fs-sm); }

  /* ========= PREMIOS ========= */
  .awards { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--hairline); }
  .award__row {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: var(--sp-3);
    padding-block: var(--sp-4);
    align-items: baseline;
  }
  .award__year { grid-column: 1; grid-row: 1 / span 3; font-size: var(--fs-lg); }
  .award__name { grid-column: 2; grid-row: 1; font-size: var(--fs-md); }
  .award__name .bold { font-weight: 700; }
  .award__level { color: var(--muted); }
  .award__project, .award__cat { grid-column: 2; font-size: var(--fs-sm); color: var(--muted); }
  .award__project { grid-row: 2; }
  .award__cat { grid-row: 3; }

  @media (min-width: 900px) {
    .award__row {
      grid-template-columns: 90px minmax(0, 1.4fr) minmax(0, 1fr) minmax(0, 1.5fr);
      align-items: center;
    }
    .award__year { grid-column: 1; grid-row: 1; font-size: var(--fs-xl); }
    .award__name { grid-column: 2; grid-row: 1; }
    .award__project { grid-column: 3; grid-row: 1; color: var(--fg); }
    .award__cat { grid-column: 4; grid-row: 1; text-align: right; }
  }
</style>
