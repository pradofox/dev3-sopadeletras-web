---
import Base from '../layouts/Base.astro';
import ProjectListEditorial from '../components/ProjectListEditorial.astro';
import Status from '../components/Status.astro';
import Float from '../components/Float.astro';
import Wink from '../components/Wink.astro';
import Logo from '../components/Logo.astro';
import { getCollection } from 'astro:content';
import { team } from '../data/team';
import { awards } from '../data/awards';

export const prerender = true;

const portfolio = (await getCollection('portfolio'))
  .filter(p => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

const featured = portfolio.slice(0, 5).map(p => ({
  href: `/trabajo/${p.id}`,
  title: p.data.title,
  client: p.data.client,
  categories: p.data.categories,
  cover: p.data.cover,
  year: p.data.year,
}));
---

<Base>
  <!-- HERO con escaleras: el señor pisa las palabras "buenas" e "ideas ;)" -->
  <section class="hero" aria-label="Inicio">
    <div class="hero__lede">
      <p>
        Desarrollamos proyectos empresariales y de impacto cultural
        a través de estrategia creativa, diseño y producción audiovisual.
      </p>
    </div>

    <div class="hero__stage">
      <!-- Grid 2x2: ideas top-right (escalón alto), buenas bot-left
           (escalón bajo). El señor en overlay centrado encima. -->
      <span class="hero__cell hero__cell--top">ideas&nbsp;<Wink /></span>
      <span class="hero__cell hero__cell--bot">buenas</span>
      <img
        src="/images/decor/senor-byn.png"
        alt=""
        class="hero__senor"
        loading="eager"
        decoding="async"
        draggable="false"
      />
    </div>

    <div class="hero__wordmark" aria-hidden="true">
      <Logo class="hero__logo" />
    </div>
  </section>

  <!-- STATUS bar -->
  <section class="status-bar wrap">
    <Status />
  </section>

  <hr class="hr" />

  <!-- TRABAJO seleccionado -->
  <section id="trabajo" class="sec sec--np">
    <header class="sec__head wrap">
      <p class="eye">Trabajo<span class="tabular">({portfolio.length})</span></p>
      <h2 class="sec__title">
        <span class="bold">Recientes</span>
        <span class="sec__title-meta tabular">/ 2024–2025</span>
      </h2>
    </header>

    <ProjectListEditorial items={featured} />

    <div class="wrap sec__more" data-reveal>
      <a href="/trabajo" class="more">
        <span>Ver los <span class="tabular">{portfolio.length}</span> proyectos</span>
        <span class="more__arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <hr class="hr" />

  <!-- NOSOTROS al estilo del actual: eyebrow + lápiz pequeño + texto central -->
  <section id="nosotros" class="nosotros sec--rel wrap">
    <p class="eye nosotros__eye">Nosotros</p>

    <Float
      src="/images/decor/pencil.png"
      alt=""
      top="34%"
      left="10%"
      size="clamp(60px, 7vw, 100px)"
      rotate="-58deg"
    />

    <p class="nosotros__text" data-reveal>
      Acompañamos a marcas y emprendedores a dar
      <span class="bold">estructura</span>,
      <span class="bold">claridad</span> y
      <span class="bold">dirección</span> a sus ideas, desde el enfoque
      hasta la ejecución. Convertimos ideas en buenas ideas <Wink />.
    </p>
  </section>

  <hr class="hr" />

  <!-- EQUIPO -->
  <section id="equipo" class="wrap sec sec--np sec--rel">
    <Float src="/images/decor/smiley.png" alt="" top="8%" right="6%" size="clamp(50px, 7vw, 90px)" rotate="14deg" />

    <header class="sec__head">
      <p class="eye">Equipo<span class="tabular">({team.length})</span></p>
    </header>

    <div class="team">
      {team.map((m, i) => (
        <article class="member" data-reveal style={`--reveal-delay: ${i * 120}ms`}>
          <span class="member__num eye tabular">{String(i+1).padStart(2,'0')} / {String(team.length).padStart(2,'0')}</span>
          <h3 class="member__name">{m.name}</h3>
          <p class="member__role">{m.role}</p>
          <blockquote class="member__quote">"{m.quote}"</blockquote>
          <ul class="member__links">
            {m.instagram && <li><a class="u" href={m.instagram} target="_blank" rel="noopener">Instagram</a></li>}
            {m.linkedin && <li><a class="u" href={m.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <hr class="hr" />

  <!-- PREMIOS -->
  <section id="premios" class="sec sec--np sec--rel">
    <Float src="/images/decor/shamrock.png" alt="" bottom="8%" left="3%" size="clamp(50px, 7vw, 100px)" rotate="-8deg" />

    <header class="wrap sec__head">
      <p class="eye">Reconocimientos<span class="tabular">({awards.length})</span></p>
    </header>

    <ul class="awards">
      {awards.map(a => (
        <li class="award" data-reveal>
          <div class="award__row wrap">
            <span class="award__year tabular">{a.year}</span>
            <span class="award__name"><span class="bold">{a.award}</span>{a.level && <span class="award__level"> · {a.level}</span>}</span>
            <span class="award__project">{a.project}</span>
            <span class="award__cat">{a.category}</span>
          </div>
          <hr class="hr" />
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  /* ========= HERO ESCALERAS =========
   * Layout: lede top-left + stage con figura del señor caminando entre
   * "buenas" (abajo, alineado con su pie de atrás) e "ideas ;)" (arriba,
   * alineado con su pie de adelante). Wordmark gigante al fondo.
   *
   * La imagen senor-byn.png tiene aspect-ratio ~107:186 (portrait, 4:7).
   * Pie de atrás (abajo): aprox 30% X / 95% Y de la imagen.
   * Pie de adelante (arriba): aprox 60% X / 60% Y de la imagen.
   */
  .hero {
    position: relative;
    min-height: calc(100dvh - 64px);
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr auto;
    padding: clamp(1rem, 4vh, 3rem) var(--gutter) 0;
    overflow: hidden;
  }

  .hero__lede {
    position: absolute;
    top: clamp(5rem, 14vh, 9rem);
    left: var(--gutter);
    z-index: 2;
    max-width: 28ch;
  }
  .hero__lede p {
    font-size: clamp(1.0625rem, 1.4vw, 1.375rem);
    line-height: 1.4;
    font-weight: 300;
    color: var(--fg);
  }

  /* Stage como grid 2x2: las palabras viven en celdas naturales,
     "ideas ;)" arriba-derecha y "buenas" abajo-izquierda. El señor
     en overlay absolute centrado encima. Sin coords mágicas: el
     layout se acomoda solo según el viewport. */
  .hero__stage {
    position: relative;
    grid-row: 1;
    align-self: end;
    width: 100%;
    min-height: clamp(380px, 65vh, 620px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }

  .hero__cell {
    font-size: clamp(1.5rem, 2.8vw, 2.5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--fg);
    z-index: 2;
    display: flex;
    padding: var(--sp-3);
  }
  /* Escalón superior (cuadrante derecho-arriba):
     centrado vertical de su celda → queda en y≈25% del stage.
     justify-start → queda hacia el centro horizontal. */
  .hero__cell--top {
    grid-row: 1;
    grid-column: 2;
    align-items: center;
    justify-content: flex-start;
    padding-left: var(--sp-5);
  }
  /* Escalón inferior (cuadrante izquierdo-abajo):
     centrado vertical de su celda → queda en y≈75% del stage.
     justify-end → queda hacia el centro horizontal. */
  .hero__cell--bot {
    grid-row: 2;
    grid-column: 1;
    align-items: center;
    justify-content: flex-end;
    padding-right: var(--sp-5);
  }

  /* El señor: overlay absolute centrado horizontal, parado en el bottom. */
  .hero__senor {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    height: 100%;
    max-height: clamp(300px, 60vh, 540px);
    width: auto;
    object-fit: contain;
    user-select: none;
    pointer-events: none;
    z-index: 1;
  }

  /* WORDMARK GIGANTE pisado al bottom, full-width */
  .hero__wordmark {
    grid-row: 2;
    width: 100%;
    line-height: 0.85;
    padding-bottom: clamp(0.5rem, 1.5vh, 1rem);
  }
  :global(.hero__logo) {
    display: block;
    width: 100%;
    height: auto;
    color: var(--fg);
  }

  /* MOBILE: stack más simple. Lede arriba, stage debajo, wordmark abajo.
     Las posiciones de las palabras se reajustan para el ancho menor. */
  @media (max-width: 720px) {
    .hero {
      padding-top: var(--sp-5);
      grid-template-rows: auto 1fr auto;
    }
    .hero__lede {
      position: static;
      grid-row: 1;
      max-width: none;
      padding-bottom: var(--sp-5);
    }
    .hero__stage {
      grid-row: 2;
      min-height: clamp(340px, 52vh, 460px);
    }
    .hero__senor { max-height: clamp(260px, 46vh, 380px); }
    .hero__cell { font-size: clamp(1.25rem, 6vw, 1.75rem); }
    .hero__wordmark { grid-row: 3; padding-bottom: var(--sp-3); }
  }

  /* ========= STATUS BAR ========= */
  .status-bar { padding-block: var(--sp-4) var(--sp-6); }

  /* ========= SECTIONS ========= */
  .sec { padding-block: clamp(3rem, 6vw, 5rem); }
  .sec--np { padding-block: clamp(3rem, 6vw, 5rem); }
  .sec--rel { position: relative; }
  .sec__head { margin-bottom: var(--sp-6); display: flex; flex-direction: column; gap: var(--sp-2); }
  .sec__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1;
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .sec__title .bold { font-weight: 700; }
  .sec__title-meta { font-size: var(--fs-md); color: var(--muted); font-weight: 300; }

  .sec__more { padding-top: var(--sp-6); display: flex; justify-content: flex-end; }
  .more {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-md);
    color: var(--fg);
    transition: opacity var(--dur);
  }
  .more__arrow { transition: transform var(--dur) var(--ease); }
  .more:hover { opacity: 0.6; }
  .more:hover .more__arrow { transform: translateX(4px); }

  /* ========= NOSOTROS (estilo del sitio actual) =========
   * Eyebrow chiquito arriba izq + lápiz pequeño en zona media + texto
   * grande centrado en columna derecha. Mucho whitespace.
   */
  .nosotros {
    padding-block: clamp(5rem, 12vw, 9rem);
    min-height: clamp(380px, 60vh, 560px);
    display: grid;
    grid-template-columns: minmax(120px, 1fr) minmax(0, 3fr);
    column-gap: clamp(1rem, 5vw, 4rem);
    align-items: start;
  }
  .nosotros__eye { grid-column: 1; grid-row: 1; }
  .nosotros__text {
    grid-column: 2;
    grid-row: 1;
    font-size: clamp(1.5rem, 2.8vw, 2.4rem);
    line-height: 1.25;
    letter-spacing: -0.02em;
    font-weight: 300;
    max-width: 22ch;
  }
  .nosotros__text .bold { font-weight: 700; }

  @media (max-width: 720px) {
    .nosotros {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }
    .nosotros__eye, .nosotros__text { grid-column: 1; }
    .nosotros__text { grid-row: 2; }
  }

  /* ========= EQUIPO ========= */
  .team {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-8);
    border-top: 1px solid var(--hairline);
    padding-top: var(--sp-5);
  }
  @media (min-width: 768px) { .team { grid-template-columns: 1fr 1fr; gap: var(--sp-10); } }
  .member { display: flex; flex-direction: column; gap: var(--sp-3); }
  .member__num { font-size: var(--fs-xs); }
  .member__name {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 300;
    letter-spacing: -0.025em;
  }
  .member__role { color: var(--muted); font-size: var(--fs-md); }
  .member__quote {
    margin: 0;
    font-size: var(--fs-md);
    color: var(--fg);
    border-left: 1px solid var(--fg);
    padding-left: var(--sp-3);
    line-height: 1.45;
    max-width: 38ch;
  }
  .member__links { list-style: none; padding: 0; margin: 0; display: flex; gap: var(--sp-4); font-size: var(--fs-sm); }

  /* ========= PREMIOS ========= */
  .awards { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--hairline); }
  .award__row {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: var(--sp-3);
    padding-block: var(--sp-4);
    align-items: baseline;
  }
  .award__year { grid-column: 1; grid-row: 1 / span 3; font-size: var(--fs-lg); }
  .award__name { grid-column: 2; grid-row: 1; font-size: var(--fs-md); }
  .award__name .bold { font-weight: 700; }
  .award__level { color: var(--muted); }
  .award__project, .award__cat { grid-column: 2; font-size: var(--fs-sm); color: var(--muted); }
  .award__project { grid-row: 2; }
  .award__cat { grid-row: 3; }

  @media (min-width: 900px) {
    .award__row {
      grid-template-columns: 90px minmax(0, 1.4fr) minmax(0, 1fr) minmax(0, 1.5fr);
      align-items: center;
    }
    .award__year { grid-column: 1; grid-row: 1; font-size: var(--fs-xl); }
    .award__name { grid-column: 2; grid-row: 1; }
    .award__project { grid-column: 3; grid-row: 1; color: var(--fg); }
    .award__cat { grid-column: 4; grid-row: 1; text-align: right; }
  }
</style>
