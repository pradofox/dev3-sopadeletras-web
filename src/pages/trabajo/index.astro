---
import Base from '../../layouts/Base.astro';
import ProjectListEditorial from '../../components/ProjectListEditorial.astro';
import Logo from '../../components/Logo.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const portfolio = (await getCollection('portfolio'))
  .filter(p => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

const items = portfolio.map(p => ({
  href: `/trabajo/${p.id}`,
  title: p.data.title,
  client: p.data.client,
  categories: p.data.categories,
  cover: p.data.cover,
  year: p.data.year,
}));
---

<Base
  title="Trabajo"
  description="Portafolio de sopadeletras®. Proyectos de estrategia creativa, branding, diseño y producción audiovisual para marcas e instituciones."
>
  <section class="head">
    <h1 class="head__title" aria-label="Trabajo">trabajo</h1>
  </section>

  <ProjectListEditorial items={items} showYear={true} />
</Base>

<style>
  .head {
    padding: clamp(2rem, 6vh, 5rem) var(--gutter) clamp(0.5rem, 1.5vh, 1rem);
    line-height: 0.85;
  }
  .head__title {
    font-size: clamp(4.5rem, 22vw, 18rem);
    line-height: 0.85;
    letter-spacing: -0.05em;
    font-weight: 300;
    color: var(--fg);
    margin: 0;
  }
</style>
