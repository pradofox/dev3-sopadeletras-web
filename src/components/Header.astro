---
import Logo from './Logo.astro';
import { site } from '../data/site';
const path = Astro.url.pathname;

const links = [
  { href: '/trabajo', label: 'trabajo' },
  { href: '/#nosotros', label: 'nosotros' },
  { href: '/#equipo', label: 'equipo' },
  { href: '/#premios', label: 'premios' },
  { href: '/contacto', label: 'contacto' },
];
---

<header class="hdr" data-theme="light">
  <div class="hdr__row">
    <a href="/" class="hdr__brand bold" aria-label={`${site.name} — inicio`}>
      <Logo class="hdr__logo" />
    </a>

    <nav class="hdr__nav" aria-label="Navegación principal">
      {links.map(it => {
        const base = it.href.split('#')[0];
        const isActive = path === it.href || (base !== '/' && path.startsWith(base));
        return (
          <a href={it.href} class:list={['hdr__link', { 'is-on': isActive }]}>{it.label}</a>
        );
      })}
    </nav>

    <button class="hdr__menu" type="button" aria-label="Menú" aria-expanded="false" id="menu-toggle">
      <span>menú</span>
    </button>
  </div>
</header>

<!-- Mobile sheet — sibling del header para evitar problemas de inheritance -->
<div class="sheet" id="menu-sheet" hidden>
  <ul class="sheet__list">
    <li><a href="/">casa</a></li>
    <li><a href="/trabajo">trabajo</a></li>
    <li><a href="/#nosotros">nosotros</a></li>
    <li><a href="/#equipo">equipo</a></li>
    <li><a href="/#premios">premios</a></li>
    <li><a href="/colofon">colofón</a></li>
    <li><a href="/contacto">contacto</a></li>
  </ul>
  <a href={`mailto:${site.email}`} class="sheet__mail u">{site.email}</a>
</div>

<style>
  /* Header sin mix-blend-mode. Items con bg gris translúcido,
   * texto negro. Logo cambia color (negro/blanco) según el [data-theme]
   * del header, que se actualiza por IntersectionObserver al pasar
   * sobre secciones marcadas data-bg="dark".
   */
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .hdr[data-theme="dark"] {
    background: transparent;
    color: var(--c-blanco);
  }

  .hdr__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--gutter) var(--sp-3);
  }

  .hdr__brand { display: inline-flex; align-items: center; }
  :global(.hdr__logo) {
    display: block;
    height: 18px;
    width: auto;
    color: var(--fg);
    transition: color var(--dur) var(--ease);
  }
  .hdr[data-theme="dark"] :global(.hdr__logo) { color: var(--c-blanco); }
  @media (min-width: 768px) { :global(.hdr__logo) { height: 22px; } }

  .hdr__nav {
    display: none;
    gap: var(--sp-2);
    justify-self: end;
    align-items: center;
  }
  .hdr__link {
    background: rgba(29, 29, 31, 0.07);
    color: var(--fg);
    padding: 6px 14px;
    font-size: var(--fs-md);
    line-height: 1.2;
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .hdr__link:hover { background: rgba(29, 29, 31, 0.14); }
  .hdr__link.is-on { background: rgba(29, 29, 31, 0.18); }
  .hdr[data-theme="dark"] .hdr__link {
    background: rgba(240, 240, 240, 0.18);
    color: var(--c-blanco);
  }
  .hdr[data-theme="dark"] .hdr__link:hover { background: rgba(240, 240, 240, 0.32); }

  .hdr__menu {
    font-size: var(--fs-md);
    padding: var(--sp-2) 0;
    color: var(--fg);
    transition: color var(--dur) var(--ease);
  }
  .hdr[data-theme="dark"] .hdr__menu { color: var(--c-blanco); }

  @media (min-width: 768px) {
    .hdr__nav { display: inline-flex; }
    .hdr__menu { display: none; }
  }

  /* Spacer para que el contenido no quede tapado */
  :global(main) { padding-top: 56px; }
  @media (min-width: 768px) { :global(main) { padding-top: 64px; } }

  /* ============ MOBILE SHEET ============ */
  .sheet {
    position: fixed;
    inset: 56px 0 0 0;
    z-index: 60;
    background: var(--bg);
    color: var(--fg);
    padding: var(--sp-6) var(--gutter);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow-y: auto;
  }
  .sheet[hidden] { display: none; }
  .sheet__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--sp-3); }
  .sheet__list a { font-size: var(--fs-2xl); letter-spacing: -0.03em; font-weight: 300; }
  .sheet__mail { font-size: var(--fs-md); color: var(--muted); margin-top: var(--sp-6); align-self: flex-start; padding-bottom: var(--sp-6); }
  @media (min-width: 768px) { .sheet { display: none !important; } }
</style>

<script>
  // Toggle del menú mobile
  const initMenu = () => {
    const btn = document.getElementById('menu-toggle');
    const sheet = document.getElementById('menu-sheet');
    if (!btn || !sheet) return;

    const close = () => {
      btn.setAttribute('aria-expanded', 'false');
      sheet.setAttribute('hidden', '');
      document.body.style.overflow = '';
    };
    const open = () => {
      btn.setAttribute('aria-expanded', 'true');
      sheet.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    };

    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      if (expanded) close(); else open();
    });
    sheet.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      // pequeño delay para dejar que la navegación arranque
      setTimeout(close, 80);
    }));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') close();
    });
    document.addEventListener('astro:before-swap', close, { once: true });
  };

  // Logo cambia color según fondo: detectamos si el header está sobre
  // una sección con data-bg="dark" usando IntersectionObserver.
  const initThemeSwap = () => {
    const hdr = document.querySelector<HTMLElement>('.hdr');
    if (!hdr) return;
    const targets = document.querySelectorAll<HTMLElement>('[data-bg="dark"]');
    if (!targets.length) {
      hdr.dataset.theme = 'light';
      return;
    }
    const headerH = hdr.offsetHeight || 56;
    const io = new IntersectionObserver((entries) => {
      // el header está "sobre" una sección dark si la sección intersecta
      // la zona top del viewport (donde vive el header sticky)
      const anyDark = Array.from(entries).some(e => e.isIntersecting);
      if (anyDark) hdr.dataset.theme = 'dark';
      else hdr.dataset.theme = 'light';
    }, {
      rootMargin: `-${headerH - 1}px 0px -${window.innerHeight - headerH - 1}px 0px`,
      threshold: 0,
    });
    targets.forEach(t => io.observe(t));
  };

  document.addEventListener('astro:page-load', () => { initMenu(); initThemeSwap(); });
  initMenu();
  initThemeSwap();
</script>
