---
import Logo from './Logo.astro';
import { site } from '../data/site';
const path = Astro.url.pathname;

const links = [
  { href: '/trabajo', label: 'trabajo' },
  { href: '/#nosotros', label: 'nosotros' },
  { href: '/#equipo', label: 'equipo' },
  { href: '/#premios', label: 'premios' },
  { href: '/contacto', label: 'contacto' },
];
---

<header class="hdr">
  <div class="hdr__row">
    <a href="/" class="hdr__brand bold" aria-label={`${site.name} — inicio`}>
      <Logo class="hdr__logo" />
    </a>

    <nav class="hdr__nav" aria-label="Navegación principal">
      {links.map(it => {
        const base = it.href.split('#')[0];
        const isActive = path === it.href || (base !== '/' && path.startsWith(base));
        return (
          <a href={it.href} class:list={['hdr__link', { 'is-on': isActive }]}>{it.label}</a>
        );
      })}
    </nav>

    <button class="hdr__menu" type="button" aria-label="Menú" aria-expanded="false" id="menu-toggle">
      <span>menú</span>
    </button>
  </div>

  <div class="hdr__sheet" id="menu-sheet" hidden>
    <ul>
      <li><a href="/">casa</a></li>
      <li><a href="/trabajo">trabajo</a></li>
      <li><a href="/#nosotros">nosotros</a></li>
      <li><a href="/#equipo">equipo</a></li>
      <li><a href="/#premios">premios</a></li>
      <li><a href="/colofon">colofón</a></li>
      <li><a href="/contacto">contacto</a></li>
    </ul>
    <a href={`mailto:${site.email}`} class="hdr__sheet-mail u">{site.email}</a>
  </div>
</header>

<style>
  /* Header con mix-blend-mode: difference para que logo + items se inviertan
   * automático según el fondo. Sobre claro = se ve negro, sobre oscuro = se
   * ve blanco. Sin JS de detección de fondo.
   */
  .hdr {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    pointer-events: none;
    mix-blend-mode: difference;
    color: #fff;
  }
  .hdr__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--gutter) var(--sp-3);
  }
  .hdr__brand, .hdr__nav, .hdr__menu { pointer-events: auto; }

  .hdr__brand { display: inline-flex; align-items: center; }
  :global(.hdr__logo) {
    display: block;
    height: 18px;
    width: auto;
    color: #fff;
  }
  @media (min-width: 768px) { :global(.hdr__logo) { height: 22px; } }

  .hdr__nav {
    display: none;
    gap: var(--sp-2);
    justify-self: end;
    align-items: center;
  }
  .hdr__link {
    /* Items con bg translúcido. Al verse a través de difference, el fondo
       gris del bg se ve como un pillbox sutil sobre cualquier color. */
    background: rgba(255, 255, 255, 0.55);
    color: #fff;
    padding: 6px 14px;
    border-radius: 0;
    font-size: var(--fs-md);
    transition: background var(--dur) var(--ease);
    line-height: 1.2;
  }
  .hdr__link:hover { background: rgba(255, 255, 255, 0.85); }
  .hdr__link.is-on { background: rgba(255, 255, 255, 0.95); }

  .hdr__menu {
    font-size: var(--fs-md);
    padding: var(--sp-2) 0;
    color: #fff;
  }

  @media (min-width: 768px) {
    .hdr__nav { display: inline-flex; }
    .hdr__menu { display: none; }
  }

  /* Spacer global: que main no quede tapado por el header fixed */
  :global(main) { padding-top: 56px; }
  @media (min-width: 768px) { :global(main) { padding-top: 64px; } }

  .hdr__sheet {
    background: var(--bg);
    color: var(--fg);
    padding: var(--sp-4) var(--gutter) var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    border-top: 1px solid var(--hairline);
    pointer-events: auto;
    mix-blend-mode: normal;
    position: fixed;
    inset: 56px 0 0 0;
    z-index: 40;
  }
  .hdr__sheet[hidden] { display: none; }
  .hdr__sheet ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--sp-2); }
  .hdr__sheet ul a { font-size: var(--fs-2xl); letter-spacing: -0.03em; font-weight: 300; }
  .hdr__sheet-mail { font-size: var(--fs-md); color: var(--muted); margin-top: var(--sp-3); align-self: flex-start; }
  @media (min-width: 768px) { .hdr__sheet { display: none !important; } }
</style>

<script>
  const initMenu = () => {
    const btn = document.getElementById('menu-toggle');
    const sheet = document.getElementById('menu-sheet');
    if (!btn || !sheet) return;
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      if (open) sheet.setAttribute('hidden', '');
      else sheet.removeAttribute('hidden');
      document.body.style.overflow = open ? '' : 'hidden';
    });
    sheet.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      btn.setAttribute('aria-expanded', 'false');
      sheet.setAttribute('hidden', '');
      document.body.style.overflow = '';
    }));
  };
  document.addEventListener('astro:page-load', initMenu);
  initMenu();
</script>
