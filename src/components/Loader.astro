---
// Loader minimal: fondo dark + letras random apareciendo en blanco.
// Solo se monta donde se importe (home). Solo dispara una vez por sesión.
// Diseño defensivo: timeout fijo de seguridad para que NUNCA se quede pegado.
---
<div id="loader" aria-hidden="true">
  <div class="loader__stage" id="loader-stage"></div>
</div>

<style>
  #loader {
    position: fixed;
    inset: 0;
    z-index: 999;
    background: var(--c-negro);
    color: var(--c-blanco);
    pointer-events: none;
    transition: opacity 700ms var(--ease);
    will-change: opacity;
  }
  #loader.is-out { opacity: 0; }
  #loader.is-done { display: none !important; }

  .loader__stage {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .loader__char {
    position: absolute;
    font-family: var(--font-sans);
    font-weight: 300;
    color: #f0f0f0;
    line-height: 1;
    user-select: none;
    pointer-events: none;
    opacity: 0;
    animation: char-pop 1500ms var(--ease) forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes char-pop {
    0%   { opacity: 0; transform: scale(0.6); }
    18%  { opacity: 1; transform: scale(1); }
    72%  { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(1.05); }
  }

  @media (prefers-reduced-motion: reduce) {
    #loader { display: none !important; }
  }
</style>

<script>
  const SESSION_KEY = 'sopa_v3_loaded_2';
  const TOTAL_MS = 1700;
  const SAFETY_MS = 3500;

  const finish = (loader: HTMLElement) => {
    loader.classList.add('is-out');
    setTimeout(() => {
      loader.classList.add('is-done');
      try { sessionStorage.setItem(SESSION_KEY, '1'); } catch {}
    }, 800);
  };

  const init = () => {
    const loader = document.getElementById('loader');
    const stage = document.getElementById('loader-stage');
    if (!loader || !stage) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      loader.classList.add('is-done');
      return;
    }

    let already = false;
    try { already = sessionStorage.getItem(SESSION_KEY) === '1'; } catch {}
    if (already) {
      loader.classList.add('is-done');
      return;
    }

    // Letras random apareciendo en posiciones random.
    const pool = 'sopadeletras®';
    const N = 24;
    const w = window.innerWidth;
    const h = window.innerHeight;

    for (let i = 0; i < N; i++) {
      const ch = pool[Math.floor(Math.random() * pool.length)];
      const el = document.createElement('span');
      el.className = 'loader__char';
      el.textContent = ch;
      const size = 12 + Math.random() * 56;
      el.style.fontSize = `${size}px`;
      el.style.left = `${Math.random() * (w - size)}px`;
      el.style.top = `${Math.random() * (h - size)}px`;
      el.style.setProperty('--d', `${Math.random() * 800}ms`);
      stage.appendChild(el);
    }

    setTimeout(() => finish(loader), TOTAL_MS);
    // Safety: SIEMPRE quitar el overlay aunque algo falle
    setTimeout(() => finish(loader), SAFETY_MS);
  };

  // Solo correr en server-rendered html (no astro:page-load porque
  // el loader vive solo en el home y no debe re-correr en SPA navigation)
  init();
</script>
