---
// Wink simétrico, ritmo de reloj digital. Cada 1s alterna `;)` y `:)`.
// Todas las instancias de la página usan el MISMO heartbeat para que
// se vea coordinado (como los `:` de un reloj).
---
<span class="wink" data-wink aria-hidden="true">;)</span>

<style>
  .wink { display: inline-block; transform: translateY(-0.04em); }
</style>

<script is:inline>
  // Heartbeat global, una sola fuente de verdad. Si ya está montado por
  // otra instancia, reusa.
  (() => {
    if ((window).__sopaWinkBeat) return;
    let on = true;
    setInterval(() => {
      on = !on;
      const winks = document.querySelectorAll('[data-wink]');
      winks.forEach((el) => { el.textContent = on ? ';)' : ':)'; });
    }, 1000);
    (window).__sopaWinkBeat = true;
  })();
</script>
