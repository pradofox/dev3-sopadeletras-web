---
import { site } from '../data/site';
import Logo from './Logo.astro';
import Wink from './Wink.astro';
const year = new Date().getFullYear();
---

<footer class="ftr">
  <hr class="hr" />

  <div class="ftr__big">
    <p class="eye">Empezar un proyecto</p>
    <a href={`mailto:${site.email}`} class="ftr__mail">
      <span class="bold">{site.email}</span>
      <span class="ftr__arrow" aria-hidden="true">→</span>
    </a>
  </div>

  <hr class="hr" />

  <div class="ftr__cols">
    <div>
      <p class="eye">Encuéntranos</p>
      <ul>
        <li><a class="u" href={site.social.instagram} target="_blank" rel="noopener">Instagram</a></li>
        <li><a class="u" href={site.social.tiktok} target="_blank" rel="noopener">TikTok</a></li>
        <li><a class="u" href={site.social.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a class="u" href={site.social.facebook} target="_blank" rel="noopener">Facebook</a></li>
      </ul>
    </div>

    <div>
      <p class="eye">Atajos</p>
      <ul>
        <li><a class="u" href="/trabajo">Trabajo</a></li>
        <li><a class="u" href="/colofon">Colofón</a></li>
        <li><a class="u" href="/contacto">Contacto</a></li>
      </ul>
    </div>

    <div>
      <p class="eye">Estado</p>
      <ul>
        <li>Disponibles para colaborar</li>
        <li>Versión <span class="tabular">v{year}.05</span></li>
      </ul>
    </div>
  </div>

  <hr class="hr" />

  <p class="ftr__address">
    <span class="bold">sopadeletras®</span>
    <span class="ftr__sep" aria-hidden="true">·</span>
    Estudio creativo en
    <span class="ftr__place">Monterrey, Nuevo León</span>
    <span class="ftr__sep" aria-hidden="true">·</span>
    México
    <span class="ftr__sep" aria-hidden="true">·</span>
    <a class="u" href={`mailto:${site.email}`}>{site.email}</a>
    <span class="ftr__sep" aria-hidden="true">·</span>
    <span class="tabular">© {year}</span>
    <span class="ftr__sep" aria-hidden="true">·</span>
    <span>Hecho con cariño desde MTY <Wink /></span>
  </p>
</footer>

<style>
  .ftr { padding-top: var(--sp-12); }

  .ftr__big {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-8) var(--gutter) var(--sp-10);
  }
  .ftr__mail {
    display: inline-flex;
    align-items: baseline;
    gap: var(--sp-3);
    transition: opacity var(--dur);
    word-break: break-word;
  }
  .ftr__mail .bold {
    font-size: clamp(2.5rem, 9vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    font-weight: 700;
  }
  .ftr__arrow {
    font-size: clamp(1.5rem, 4vw, 3rem);
    color: var(--muted);
    transition: transform var(--dur) var(--ease);
  }
  .ftr__mail:hover { opacity: 0.65; }
  .ftr__mail:hover .ftr__arrow { transform: translateX(8px); }

  .ftr__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    padding: var(--sp-6) var(--gutter);
  }
  @media (min-width: 720px) { .ftr__cols { grid-template-columns: repeat(3, 1fr); gap: var(--sp-8); } }
  .ftr__cols ul { list-style: none; padding: 0; margin: var(--sp-3) 0 0; display: flex; flex-direction: column; gap: 4px; font-size: var(--fs-md); }

  .ftr__address {
    padding: var(--sp-5) var(--gutter) var(--sp-6);
    font-size: var(--fs-sm);
    color: var(--muted);
    line-height: 1.7;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    align-items: baseline;
  }
  .ftr__address .bold { color: var(--fg); font-size: var(--fs-md); }
  .ftr__address .ftr__place { color: var(--fg); }
  .ftr__sep { opacity: 0.5; }
</style>
